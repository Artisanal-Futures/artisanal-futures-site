# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

DATABASE_URL='postgres://myuser:mypassword@localhost:3377/mydatabase'


#/--------------------------------
# AI Agent Version 0.1.0
AI_AGENT_BACKEND_URL=

#/--------------------------------
# Auth Providers
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000" # or "https://artisanalfutures.org" or "https://dev.artisanalfutures.org"
BETTER_AUTH_DISCORD_ID=
BETTER_AUTH_DISCORD_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER=
HOSTNAME="localhost" # or "dev.artisanalfutures.org" or "artisanalfutures.org"

#/--------------------------------
# Emails
RESEND_API_KEY=
NEXT_PUBLIC_EMAIL_FROM_NOREPLY=no-reply@artisanalfutures.org
NEXT_PUBLIC_EMAIL_FROM_SUPPORT=support@artisanalfutures.org

#/--------------------------------
# Website Provisioning
COOLIFY_API=
COOLIFY_ADMIN_SAFE_API_TOKEN=
COOLIFY_UUID=
WORDPRESS_DOCKER_REGISTRY=

# SimplePress integration
SIMPLEPRESS_API_URL=https://simplepress.dev
SIMPLEPRESS_API_TOKEN=
SIMPLEPRESS_CALLBACK_TOKEN=
AF_SP_WEBHOOK_SECRET=
# DEPRECATED: replaced by SIMPLEPRESS_CALLBACK_TOKEN + AF_SP_WEBHOOK_SECRET; remove at cutover
SIMPLEPRESS_HASH_SECRET=

#/--------------------------------
# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=


#/--------------------------------
# HCaptcha
HCAPTCHA_SECRET_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

#/--------------------------------
# Storage
NEXT_PUBLIC_STORAGE_URL=
NEXT_PUBLIC_STORAGE_BUCKET_NAME=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=

#/--------------------------------
# Voting
NEXT_PUBLIC_VOTE_DISABLED=false
NEXT_PUBLIC_HEART_VOTE_DISABLED=false
NEXT_PUBLIC_NEGATIVE_VOTE_DISABLED=false

#/--------------------------------
# Help Docs
NEXT_PUBLIC_HELP_DOCS_URL=
