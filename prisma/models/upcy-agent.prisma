// These are for the v0.1.0 of UPCY. Currently not in use.



model GeneratedImages {
  id           String @id @default(cuid())
  userId       String
  projectTitle String
  prompt       String
  imageUrl     String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GenerationSurvey {
  id                       String @id @default(cuid())
  userId                   String
  projectTitle             String
  levelOfStatisfaction     String
  directDigitalFabrication String
  user                     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Variation {
  id             String @id @default(cuid())
  userId         String
  projectTitle   String
  guidancePrompt String
  imageUrl       String
  exceutionTime  String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Modification {
  id             String @id @default(cuid())
  userId         String
  projectTitle   String
  guidanceScale  String
  prompt         String
  negativePrompt String
  exceutionTime  String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
