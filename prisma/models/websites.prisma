model WebsiteProvision {
  id                     String          @id @default(cuid())
  framework              Framework
  siteType               SiteType
  status                 ProvisionStatus @default(PENDING)

  customDomain           String?         @unique //coolname.com
  subdomain              String?         @unique //coolname
  deploymentUrl          String?                 //coolname.simplepress.dev or simplepress.artisanalfutures.shop

  businessName           String
  contactEmail           String

  config                 Json 
  errorMessage           String?

  deletedAt              DateTime?
 
  coolifyProjectUuid     String?         @unique
  coolifyServerUuid      String?
  coolifyDatabaseUuid    String?
  coolifyServiceUuid     String?         @unique

  adminPasswordEncrypted String?
  adminUser              String?

  username               String?
  password               String?

  accessToken            String?         @unique

  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  shopId                 String
  shop                   Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userId                 String
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@unique([shopId, framework])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([framework])
  @@index([status])
  @@index([subdomain])
  @@index([userId])
}

enum ProvisionStatus {
  PENDING
  PROVISIONING
  BUILDING
  DEPLOYING
  ACTIVE
  FAILED
  SUSPENDED
  DELETING
  DELETED
}

enum SiteType {
  ECOMMERCE
  BLOG
  PORTFOLIO
  LANDING_PAGE
  BUSINESS
  CUSTOM
}

enum Framework {
  WORDPRESS
  NEXTJS
}
