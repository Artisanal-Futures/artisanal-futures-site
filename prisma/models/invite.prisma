model PlatformInvite {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  // Who is this for?
  email       String
  code        String   @unique // Used in wizard URL
  
  // What role will they have?
  role        Role   
    
  // Status
  used        Boolean   @default(false)
  usedAt      DateTime?
  usedBy      String?   // userId who redeemed it
  
  // Who created this invite
  createdBy   String?
  creator     User?     @relation("CreatedInvites", fields: [createdBy], references: [id], onDelete: SetNull)
  
  @@index([email])
  @@index([code])
}