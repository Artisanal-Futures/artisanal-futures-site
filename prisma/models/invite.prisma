model PlatformInvite {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime
  email     String
  code      String    @unique
  role      Role
  used      Boolean   @default(false)
  usedAt    DateTime?
  usedBy    String?
  createdBy String?
  shopId    String?
  creator   User?     @relation("CreatedInvites", fields: [createdBy], references: [id])
  shop      Shop?     @relation("ShopInvites", fields: [shopId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([code])
  @@index([shopId])
}
