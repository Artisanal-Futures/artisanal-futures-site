model Event{
    id String @id @default(cuid())

    shopId String
    shop Shop @relation(fields: [shopId], references: [id])

    title String
    description String @db.Text

    startDate DateTime
    endDate DateTime?
    location String?

    imageUrl String?

    callToActionLink String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}