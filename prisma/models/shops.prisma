model Shop {
  id               String            @id @default(cuid())
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id], onDelete: NoAction)

  websiteProvision WebsiteProvision?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Public Information
  name             String
  ownerName        String
  ownerPhoto       String?
  bio              String?   // Bio is of the shop owner. Since this is a platform for artisans, we want to show off the artisans here.
  description      String?   // This is the description of the shop itself. What does the owner want to share with site visitors?
  logoPhoto        String?
  phone            String?
  email            String?
  website          String?
  attributeTags    String[]
  products         Product[]
  services         Service[]
  address          ShopAddress?
  events           Event[]

  // Decommissioned Fields
  coverPhoto       String?
}

model ShopAddress {
  id         String  @id @default(cuid())
  address    String?
  additional String?
  city       String?
  state      String?
  zip        String?
  country    String?
  shopId     String? @unique
  street     String?
  shop       Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)
}